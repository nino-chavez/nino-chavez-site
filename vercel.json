{
  "rewrites": [
    {
      "source": "/photography",
      "destination": "https://nino-chavez-gallery.vercel.app/photography"
    },
    {
      "source": "/photography/:path*",
      "destination": "https://nino-chavez-gallery.vercel.app/photography/:path*"
    },
    {
      "source": "/blog",
      "destination": "https://signal-dispatch-blog.vercel.app/blog"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://signal-dispatch-blog.vercel.app/blog/:path*"
    },
    {
      "source": "/labs",
      "destination": "https://nino-chavez-labs.vercel.app/labs"
    },
    {
      "source": "/labs/:path*",
      "destination": "https://nino-chavez-labs.vercel.app/labs/:path*"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
