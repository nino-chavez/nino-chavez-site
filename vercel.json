{
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/cv",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/photo/:path*",
      "destination": "/photography/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/gallery/sitemap.xml",
      "destination": "https://photography.ninochavez.co/sitemap.xml"
    },
    {
      "source": "/content/:path*",
      "destination": "https://blog.ninochavez.co/content/:path*"
    },
    {
      "source": "/blog/sitemap-index.xml",
      "destination": "https://blog.ninochavez.co/sitemap-index.xml"
    },
    {
      "source": "/blog/sitemap-0.xml",
      "destination": "https://blog.ninochavez.co/sitemap-0.xml"
    },
    {
      "source": "/blog/sitemap.xml",
      "destination": "https://blog.ninochavez.co/sitemap.xml"
    },
    {
      "source": "/blog/rss.xml",
      "destination": "https://blog.ninochavez.co/rss.xml"
    },
    {
      "source": "/photography",
      "destination": "https://photography.ninochavez.co/photography"
    },
    {
      "source": "/photography/",
      "destination": "https://photography.ninochavez.co/photography/"
    },
    {
      "source": "/photography/:path*",
      "destination": "https://photography.ninochavez.co/photography/:path*"
    },
    {
      "source": "/blog",
      "destination": "https://blog.ninochavez.co/blog"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.ninochavez.co/blog/:path*"
    },
    {
      "source": "/_astro/:path*",
      "destination": "https://blog.ninochavez.co/_astro/:path*"
    },
    {
      "source": "/generated/:path*",
      "destination": "https://blog.ninochavez.co/generated/:path*"
    },
    {
      "source": "/images/generated/:path*",
      "destination": "https://blog.ninochavez.co/images/generated/:path*"
    },
    {
      "source": "/code-to-cognition",
      "destination": "https://code-to-cognition.vercel.app/labs/code-to-cognition"
    },
    {
      "source": "/code-to-cognition/:path*",
      "destination": "https://code-to-cognition.vercel.app/labs/code-to-cognition/:path*"
    },
    {
      "source": "/code-to-cognition",
      "destination": "https://code-to-cognition.vercel.app/labs/code-to-cognition"
    },
    {
      "source": "/code-to-cognition/:path*",
      "destination": "https://code-to-cognition.vercel.app/labs/code-to-cognition/:path*"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
